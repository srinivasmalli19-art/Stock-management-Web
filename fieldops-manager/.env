NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=fieldops
DATABASE_URL=postgresql://admin:secret@localhost:5432/fieldops

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS (Production)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=fieldops-frontend
AWS_CLOUDFRONT_DIST_ID=your_distribution_id
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net
