generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Super_Admin
  Admin
  Store_Manager
  Team_Leader
  Engineer
}

enum ProductivityStatus {
  Pending
  Validated
  Approved
  Rejected
}

enum AttendanceStatus {
  Present
  Absent
}

enum StockRequestStatus {
  Pending
  Approved
  Rejected
  Revoke_Pending
  Revoked
}

enum PurchaseStatus {
  Pending
  Approved
  Rejected
}

enum RevokeStatus {
  Revoke_Pending
  Revoked
  Rejected
}

// ─── Organisation ─────────────────────────────────────────────────────────────

model Organisation {
  id        String  @id @default(cuid())
  name      String
  siteCode  String  @unique
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  skus             Sku[]
  mainInventory    MainInventory[]
  engineerStock    EngineerStock[]
  productivityLogs ProductivityLog[]
  attendance       Attendance[]
  stockRequests    StockRequest[]
  revokeRequests   RevokeRequest[]
  purchaseInward   PurchaseInward[]
  lpRequests       LpRequest[]
  claimRequests    ClaimRequest[]
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(Engineer)
  isActive     Boolean  @default(true)
  // orgId is nullable: Super_Admin has global access (orgId = null)
  orgId        String?
  org          Organisation? @relation(fields: [orgId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engineerStock    EngineerStock[]
  productivityLogs ProductivityLog[]
  stockRequests    StockRequest[]
  attendance       Attendance[]
  refreshTokens    RefreshToken[]

  @@index([orgId])
  @@index([orgId, role])
  @@index([orgId, isActive])
}

// ─── SKUs & Inventory ─────────────────────────────────────────────────────────

model Sku {
  id            String  @id
  name          String
  lowStockAlert Int     @default(0)
  orgId         String?
  org           Organisation? @relation(fields: [orgId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mainInventory     MainInventory?
  engineerStock     EngineerStock[]
  productivityItems ProductivityItem[]
  stockRequests     StockRequest[]
  purchaseInward    PurchaseInward[]

  @@index([orgId])
}

model MainInventory {
  id        String  @id @default(cuid())
  skuId     String  @unique
  sku       Sku     @relation(fields: [skuId], references: [id])
  qty       Int     @default(0)
  unitPrice Float   @default(0)
  orgId     String?
  org       Organisation? @relation(fields: [orgId], references: [id])
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model EngineerStock {
  id         String  @id @default(cuid())
  engineerId String
  engineer   User    @relation(fields: [engineerId], references: [id])
  skuId      String
  sku        Sku     @relation(fields: [skuId], references: [id])
  qty        Int     @default(0)
  orgId      String?
  org        Organisation? @relation(fields: [orgId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([engineerId, skuId])
  @@index([orgId])
  @@index([orgId, engineerId])
}

// ─── Productivity ─────────────────────────────────────────────────────────────

model ProductivityLog {
  id          String             @id @default(cuid())
  engineerId  String
  engineer    User               @relation(fields: [engineerId], references: [id])
  date        DateTime           @db.Date
  callsClosed Int                @default(0)
  status      ProductivityStatus @default(Pending)
  tlNote      String?
  adminNote   String?
  orgId       String?
  org         Organisation?      @relation(fields: [orgId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items      ProductivityItem[]
  attendance Attendance?

  @@unique([engineerId, date])
  @@index([orgId])
  @@index([orgId, date])
  @@index([orgId, status])
}

model ProductivityItem {
  id                String          @id @default(cuid())
  productivityLogId String
  log               ProductivityLog @relation(fields: [productivityLogId], references: [id], onDelete: Cascade)
  skuId             String
  sku               Sku             @relation(fields: [skuId], references: [id])
  qty               Int
  saleValue         Float           @default(0)
  adminIncentive    Float?
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id                String           @id @default(cuid())
  engineerId        String
  engineer          User             @relation(fields: [engineerId], references: [id])
  date              DateTime         @db.Date
  status            AttendanceStatus @default(Present)
  productivityLogId String?          @unique
  log               ProductivityLog? @relation(fields: [productivityLogId], references: [id])
  orgId             String?
  org               Organisation?    @relation(fields: [orgId], references: [id])

  @@unique([engineerId, date])
  @@index([orgId])
  @@index([orgId, date])
}

// ─── Stock Requests ───────────────────────────────────────────────────────────

model StockRequest {
  id         String             @id @default(cuid())
  engineerId String
  engineer   User               @relation(fields: [engineerId], references: [id])
  skuId      String
  sku        Sku                @relation(fields: [skuId], references: [id])
  qty        Int
  status     StockRequestStatus @default(Pending)
  note       String?
  orgId      String?
  org        Organisation?      @relation(fields: [orgId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  revokeRequest RevokeRequest?

  @@index([orgId])
  @@index([orgId, status])
}

model RevokeRequest {
  id             String       @id @default(cuid())
  stockRequestId String       @unique
  stockRequest   StockRequest @relation(fields: [stockRequestId], references: [id])
  engineerId     String
  skuId          String
  qty            Int
  status         RevokeStatus @default(Revoke_Pending)
  orgId          String?
  org            Organisation? @relation(fields: [orgId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, status])
}

// ─── Purchase Inward ──────────────────────────────────────────────────────────

model PurchaseInward {
  id        String         @id @default(cuid())
  skuId     String
  sku       Sku            @relation(fields: [skuId], references: [id])
  qty       Int
  unitPrice Float
  vendor    String
  invoiceNo String
  date      DateTime       @db.Date
  status    PurchaseStatus @default(Pending)
  orgId     String?
  org       Organisation?  @relation(fields: [orgId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, status])
}

// ─── LP & Claim Requests ──────────────────────────────────────────────────────

model LpRequest {
  id           String        @id @default(cuid())
  requestId    String        @unique
  jobId        String
  spareCost    Float
  serviceCost  Float
  totalCost    Float
  description  String
  tlEmail      String
  requestDate  DateTime      @db.Date
  status       String        @default("LP_PENDING_ADMIN_APPROVAL")
  adminRemarks String?
  approvedBy   String?
  approvedAt   DateTime?
  note         String?
  orgId        String?
  org          Organisation? @relation(fields: [orgId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  claim ClaimRequest?

  @@index([orgId])
  @@index([orgId, status])
}

model ClaimRequest {
  id                String    @id @default(cuid())
  lpRequestId       String    @unique
  claimAmount       Float
  remarks           String
  status            String    @default("CLAIM_VALIDATION_PENDING")
  validatedBy       String?
  validatedAt       DateTime?
  validationRemarks String?
  approvedBy        String?
  approvedAt        DateTime?
  approvalRemarks   String?
  orgId             String?
  org               Organisation? @relation(fields: [orgId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lpRequest LpRequest @relation(fields: [lpRequestId], references: [id])

  @@index([orgId])
  @@index([orgId, status])
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
}
