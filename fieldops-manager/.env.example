NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fieldops
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fieldops

# Redis (optional — not required for core functionality)
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate strong random values for production)
JWT_ACCESS_SECRET=your_jwt_access_secret_min_64_chars_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS (optional — only needed if using S3/CloudFront for frontend hosting)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CLOUDFRONT_DIST_ID=your_cloudfront_distribution_id
AWS_CLOUDFRONT_URL=your_cloudfront_domain.cloudfront.net
